{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": false,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_SUPABASE_URL": "TON_URL_SUPABASE",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "TA_CLE_ANON_SUPABASE"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_SUPABASE_URL": "TON_URL_SUPABASE",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "TA_CLE_ANON_SUPABASE"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {},
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production"
      }
    }
  }
}