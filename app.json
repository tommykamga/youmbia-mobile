{
  "expo": {
    "name": "YOUMBIA",
    "slug": "youmbia-mobile",
    "version": "3.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "youmbiamobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.youmbia.mobile",
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0B6B3A"
      }
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B6B3A"
    },
    "android": {
      "package": "com.youmbia.mobile",
      "versionCode": 19,
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0B6B3A"
      },
      "adaptiveIcon": {
        "backgroundColor": "#0B6B3A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "www.youmbia.com",
              "pathPrefix": "/annonce"
            },
            {
              "scheme": "https",
              "host": "youmbia.com",
              "pathPrefix": "/annonce"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "eas": {
        "projectId": "2869afc2-e13f-48b5-8e78-acbe5186934c"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications",
      "expo-image-picker"
    ]
  }
}